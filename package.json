    "d3": "^7.9.0",
    "d3-voronoi-treemap": "^1.1.2",
    "less": "^3.0.1",
    "less-plugin-clean-css": "^1.5.1",
    "rollup": "^4.57.1",
    "rollup-plugin-node-resolve": "^5.1.0",
    "rollup-plugin-uglify": "^4.0.0"
  },
  "engines": {
    "node": "24.12.x",
    "npm": "11.x"
